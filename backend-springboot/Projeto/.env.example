# Porta HTTP em que a aplicação vai escutar (o Render injeta isso automaticamente em runtime)
PORT=8080

# --- Banco de Dados (PostgreSQL / Supabase) ---
# Host do banco de dados (ex: db.xxxxxxxx.supabase.co)
DB_HOST=localhost
# Porta do banco de dados
DB_PORT=5433
# Nome do banco de dados
DB_NAME=musicmakers_db
# Usuário de conexão com o banco de dados
DB_USER=postgres
# Senha de conexão com o banco de dados
DB_PASSWORD=sua_senha_aqui
# Modo SSL da conexão JDBC (ex: require em produção com Supabase, prefer em dev local)
DB_SSLMODE=prefer

# --- Segurança ---
# Chave secreta usada para assinar/validar os tokens JWT (defina um valor forte em produção)
JWT_SECRET=sua_chave_secreta_aqui

# --- Migrations / JPA ---
# Habilita/desabilita a execução automática das migrations Flyway no boot
SPRING_FLYWAY_ENABLED=true
# Estratégia do Hibernate para o schema (validate recomendado em produção)
JPA_DDL_AUTO=validate
# Exibe (ou não) as queries SQL geradas pelo Hibernate no log
JPA_SHOW_SQL=false

# --- E-mail (API HTTP do Resend - não SMTP, pois o Render bloqueia portas SMTP de saída) ---
# Chave de API gerada em https://resend.com/api-keys
RESEND_API_KEY=re_sua_chave_aqui
# Remetente dos e-mails. Sem domínio próprio verificado no Resend, use o domínio de testes
# (só envia para o e-mail da própria conta Resend): "MusicMakers <onboarding@resend.dev>"
RESEND_FROM_EMAIL=MusicMakers <onboarding@resend.dev>

# --- URL do frontend (usada para montar o link de redefinição de senha no e-mail) ---
FRONTEND_URL=http://localhost:5500

# --- CORS ---
# Lista de origens permitidas, separadas por vírgula (sem espaços)
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://127.0.0.1:5500,http://localhost:5500,http://localhost:8080

# --- Google OAuth ---
# Client ID do OAuth do Google usado para validar o login social
GOOGLE_CLIENT_ID=seu_google_client_id_aqui

# --- Logging ---
# Nível de log do Spring Security (ex: INFO em produção, DEBUG para depuração)
LOG_LEVEL_SECURITY=INFO
# Nível de log do Spring Web (ex: INFO em produção, DEBUG para depuração)
LOG_LEVEL_WEB=INFO
