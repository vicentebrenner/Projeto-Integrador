<?xml version="1.0" encoding="utf-8"?>
<!--
    Regras de backup do aplicativo.
    SharedPreferences são incluídas no backup para manter sessão do usuário.
    Ver: https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!-- Inclui as SharedPreferences do usuário no backup -->
    <include domain="sharedpref" path="." />
</full-backup-content>